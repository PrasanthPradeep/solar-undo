# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Block all hidden folders by default
.*/

# Block all hidden root-level files by default
.*

# Explicitly allow vital open-source infrastructure and configs
!.gitignore
!.github/
!.vscode/

# Block personal VS Code overrides & local history
.vscode/tasks.json
.vscode/settings.json
.vscode/.history/

# 5. Hard safety net for secrets and OS-specific junk
.env
.env.local
.DS_Store
Thumbs.db


# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database backups
/db/backups/
